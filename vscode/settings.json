{
  // =========================================================================
  // VS Code Settings
  // Theme: Solarized Light | Vim Mode Enabled
  // =========================================================================

  // -------------------------------------------------------------------------
  // Appearance
  // -------------------------------------------------------------------------
  "workbench.colorTheme": "Solarized Light",
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.activityBar.location": "default",
  "workbench.sideBar.location": "left",
  "workbench.tree.indent": 16,

  // -------------------------------------------------------------------------
  // Editor
  // -------------------------------------------------------------------------
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'SF Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.fontLigatures": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.rulers": [88, 120],
  "editor.wordWrap": "off",
  "editor.minimap.enabled": false,
  "editor.scrollBeyondLastLine": false,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "block",
  "editor.renderWhitespace": "selection",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.linkedEditing": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.lineNumbers": "relative",
  "editor.smoothScrolling": true,
  "editor.stickyScroll.enabled": true,

  // -------------------------------------------------------------------------
  // Vim Extension Settings
  // -------------------------------------------------------------------------
  "vim.enable": true,
  "vim.leader": "<space>",
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-b>": true,
    "<C-c>": true,
    "<C-d>": true,
    "<C-e>": true,
    "<C-h>": true,
    "<C-j>": true,
    "<C-k>": true,
    "<C-l>": true,
    "<C-n>": false,
    "<C-p>": false,
    "<C-u>": true,
    "<C-w>": true,
    "<C-x>": false,
    "<C-y>": true,
    "<C-z>": false
  },
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    // Clear search highlight
    {
      "before": ["<Esc>"],
      "commands": [":nohlsearch"]
    },
    // Save file
    {
      "before": ["<leader>", "w"],
      "commands": [":w"]
    },
    // Close editor
    {
      "before": ["<leader>", "q"],
      "commands": [":q"]
    },
    // File explorer
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.view.explorer"]
    },
    // Toggle sidebar
    {
      "before": ["<leader>", "b"],
      "commands": ["workbench.action.toggleSidebarVisibility"]
    },
    // Quick open (find files)
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    // Find in files (grep)
    {
      "before": ["<leader>", "f", "g"],
      "commands": ["workbench.action.findInFiles"]
    },
    // Find symbol in workspace
    {
      "before": ["<leader>", "f", "s"],
      "commands": ["workbench.action.showAllSymbols"]
    },
    // Go to definition
    {
      "before": ["g", "d"],
      "commands": ["editor.action.revealDefinition"]
    },
    // Go to type definition
    {
      "before": ["g", "y"],
      "commands": ["editor.action.goToTypeDefinition"]
    },
    // Go to implementation
    {
      "before": ["g", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    // Find references
    {
      "before": ["g", "r"],
      "commands": ["editor.action.goToReferences"]
    },
    // Hover (show documentation)
    {
      "before": ["K"],
      "commands": ["editor.action.showHover"]
    },
    // Rename symbol
    {
      "before": ["<leader>", "r", "n"],
      "commands": ["editor.action.rename"]
    },
    // Code actions
    {
      "before": ["<leader>", "c", "a"],
      "commands": ["editor.action.quickFix"]
    },
    // Format document
    {
      "before": ["<leader>", "l", "f"],
      "commands": ["editor.action.formatDocument"]
    },
    // Next/prev diagnostic
    {
      "before": ["]", "d"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["[", "d"],
      "commands": ["editor.action.marker.prev"]
    },
    // Split window vertical
    {
      "before": ["<leader>", "v"],
      "commands": ["workbench.action.splitEditor"]
    },
    // Split window horizontal
    {
      "before": ["<leader>", "s"],
      "commands": ["workbench.action.splitEditorDown"]
    },
    // Navigate splits (like vim-tmux-navigator)
    {
      "before": ["<C-h>"],
      "commands": ["workbench.action.focusLeftGroup"]
    },
    {
      "before": ["<C-j>"],
      "commands": ["workbench.action.focusBelowGroup"]
    },
    {
      "before": ["<C-k>"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["<C-l>"],
      "commands": ["workbench.action.focusRightGroup"]
    },
    // Buffer navigation
    {
      "before": ["<S-h>"],
      "commands": ["workbench.action.previousEditor"]
    },
    {
      "before": ["<S-l>"],
      "commands": ["workbench.action.nextEditor"]
    },
    // Close buffer
    {
      "before": ["<leader>", "b", "d"],
      "commands": ["workbench.action.closeActiveEditor"]
    },
    // Terminal toggle
    {
      "before": ["<leader>", "t"],
      "commands": ["workbench.action.terminal.toggleTerminal"]
    },
    // Git
    {
      "before": ["<leader>", "g", "s"],
      "commands": ["workbench.view.scm"]
    },
    {
      "before": ["<leader>", "g", "b"],
      "commands": ["gitlens.toggleFileBlame"]
    },
    // Command palette
    {
      "before": ["<leader>", "p"],
      "commands": ["workbench.action.showCommands"]
    },
    // Center cursor
    {
      "before": ["<C-d>"],
      "after": ["<C-d>", "z", "z"]
    },
    {
      "before": ["<C-u>"],
      "after": ["<C-u>", "z", "z"]
    },
    {
      "before": ["n"],
      "after": ["n", "z", "z", "z", "v"]
    },
    {
      "before": ["N"],
      "after": ["N", "z", "z", "z", "v"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    // Move lines
    {
      "before": ["J"],
      "commands": ["editor.action.moveLinesDownAction"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.moveLinesUpAction"]
    },
    // Stay in visual mode after indent
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"],
      "after": ["g", "v"]
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"],
      "after": ["g", "v"]
    }
  ],
  "vim.statusBarColorControl": false,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.duration": 150,
  "vim.foldfix": true,
  "vim.easymotion": true,
  "vim.surround": true,

  // -------------------------------------------------------------------------
  // Terminal
  // -------------------------------------------------------------------------
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.defaultProfile.osx": "bash",
  "terminal.integrated.defaultProfile.linux": "bash",

  // -------------------------------------------------------------------------
  // Files
  // -------------------------------------------------------------------------
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/*.pyc": true,
    "**/.venv": true,
    "**/venv": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true
  },

  // -------------------------------------------------------------------------
  // Search
  // -------------------------------------------------------------------------
  "search.exclude": {
    "**/node_modules": true,
    "**/.venv": true,
    "**/venv": true,
    "**/__pycache__": true,
    "**/dist": true,
    "**/build": true
  },

  // -------------------------------------------------------------------------
  // Python
  // -------------------------------------------------------------------------
  "[python]": {
    "editor.tabSize": 4,
    "editor.rulers": [88, 120],
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit"
    }
  },
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,

  // -------------------------------------------------------------------------
  // JavaScript / TypeScript
  // -------------------------------------------------------------------------
  "[javascript]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // -------------------------------------------------------------------------
  // Clojure
  // -------------------------------------------------------------------------
  "[clojure]": {
    "editor.tabSize": 2,
    "editor.autoClosingBrackets": "always",
    "editor.formatOnSave": true
  },
  "calva.paredit.defaultKeyMap": "original",
  "calva.prettyPrintingOptions": {
    "enabled": true,
    "width": 80
  },

  // -------------------------------------------------------------------------
  // Bash / Shell
  // -------------------------------------------------------------------------
  "[shellscript]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },

  // -------------------------------------------------------------------------
  // HTML / CSS / Markdown
  // -------------------------------------------------------------------------
  "[html]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.rulers": [],
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    }
  },

  // -------------------------------------------------------------------------
  // Git
  // -------------------------------------------------------------------------
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "always",
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.codeLens.enabled": false,
  "gitlens.currentLine.enabled": false,

  // -------------------------------------------------------------------------
  // Extensions
  // -------------------------------------------------------------------------
  "extensions.autoCheckUpdates": true,
  "extensions.autoUpdate": true,

  // -------------------------------------------------------------------------
  // Telemetry
  // -------------------------------------------------------------------------
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false
}
