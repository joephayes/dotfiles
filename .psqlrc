-- ~/.psqlrc

\set QUIET 1

-- Prompt: user@host:port/db
\set PROMPT1 '%n@%m:%>/%/%# '
\set PROMPT2 '%R%# '

-- History
\set HISTCONTROL ignoreboth
\set HISTFILE ~/.psql_history- :DBNAME
\set HISTSIZE 5000

-- Output
\pset null '[NULL]'
\pset linestyle unicode
\pset border 2
\x auto
\timing on

-- Useful queries
\set activity 'SELECT pid, usename, state, left(query, 60) FROM pg_stat_activity WHERE state != \'idle\';'
\set locks 'SELECT pid, usename, pg_blocking_pids(pid) as blocked_by, left(query, 60) FROM pg_stat_activity WHERE cardinality(pg_blocking_pids(pid)) > 0;'
\set tablesize 'SELECT tablename, pg_size_pretty(pg_total_relation_size(schemaname||\'.\'||tablename)) FROM pg_tables ORDER BY pg_total_relation_size(schemaname||\'.\'||tablename) DESC LIMIT 10;'
\set dbsize 'SELECT datname, pg_size_pretty(pg_database_size(datname)) FROM pg_database ORDER BY pg_database_size(datname) DESC;'

\set QUIET 0
