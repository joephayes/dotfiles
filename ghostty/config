# ~/.config/ghostty/config

theme = iTerm2 Solarized Light

# Terminal identity - use xterm-256color for maximum remote compat
# This avoids needing to install ghostty terminfo on remote hosts
term = xterm-256color

# Font
font-family = "JetBrains Mono"
font-size = 11

# Window
window-padding-x = 8
window-padding-y = 8

# Scrollback
scrollback-limit = 10000

# Don't let Ghostty steal keys that remote apps need
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+up=unbind
keybind = alt+down=unbind

# Cursor
cursor-style = block
cursor-style-blink = false

# Shell integration - disable on remote (SSH handles its own)
shell-integration = detect

copy-on-select = clipboard
clipboard-read = allow
clipboard-write = allow
